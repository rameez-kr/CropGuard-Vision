APP_ENV=development
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=DEBUG

CUSTOM_VISION_PREDICTION_ENDPOINT=https://YOUR_REGION.api.cognitive.microsoft.com/
CUSTOM_VISION_PREDICTION_KEY=your_key_here
CUSTOM_VISION_PROJECT_ID=your_project_id_here
CUSTOM_VISION_PUBLISH_NAME=cropguard-v1

AI_VISION_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
AI_VISION_KEY=your_key_here

AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=your_key_here
AZURE_OPENAI_DEPLOYMENT=gpt-4o-mini
AZURE_OPENAI_API_VERSION=2024-08-01-preview

SPEECH_KEY=your_key_here
SPEECH_REGION=eastus

LANGUAGE_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
LANGUAGE_KEY=your_key_here

TRANSLATOR_KEY=your_key_here
TRANSLATOR_ENDPOINT=https://api.cognitive.microsofttranslator.com
TRANSLATOR_REGION=eastus

CONTENT_SAFETY_ENDPOINT=https://your-resource.cognitiveservices.azure.com/
CONTENT_SAFETY_KEY=your_key_here

BLOB_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...;AccountKey=...;EndpointSuffix=core.windows.net
BLOB_CONTAINER_NAME=leaf-images

JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRE_MINUTES=10080
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
